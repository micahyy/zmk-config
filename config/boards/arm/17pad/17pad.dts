/dts-v1/;
#include <nrf52840.dtsi>

/ {
    model = "17Pad";
    compatible = "17pad";

    chosen {
        zephyr,code-partition = &code_partition;
        zephyr,sram = &sram0;
        zephyr,flash = &flash0;
        zmk,kscan = &kscan0;
        zmk,matrix-transform = &default_transform;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        wakeup-source;

        // 5行 × 4列
        row-gpios
            = <&gpio0 13 (GPIO_ACTIVE_HIGH)>
            , <&gpio0 14 (GPIO_ACTIVE_HIGH)>
            , <&gpio0 15 (GPIO_ACTIVE_HIGH)>
            , <&gpio0 16 (GPIO_ACTIVE_HIGH)>
            , <&gpio0 17 (GPIO_ACTIVE_HIGH)>;
        col-gpios
            = <&gpio0 20 (GPIO_ACTIVE_HIGH)>
            , <&gpio0 21 (GPIO_ACTIVE_HIGH)>
            , <&gpio0 22 (GPIO_ACTIVE_HIGH)>
            , <&gpio0 23 (GPIO_ACTIVE_HIGH)>;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <4>;
        rows = <5>;

        // 按照物理布局映射
        // 空缺位置用 RC(0,0) 占位但实际不连接
        map = <
            RC(0,0) RC(0,1) RC(0,2) RC(0,3)
            RC(1,0) RC(1,1) RC(1,2) RC(2,3)   // row1 col3 实际映射到矩阵 [2,3]
            RC(2,0) RC(2,1) RC(2,2) RC(3,3)   // row2 col3 实际映射到矩阵 [3,3]
            RC(3,0) RC(3,1) RC(3,2) RC(0,0)   // row3 col3 占位（无按键）
            RC(4,0) RC(4,1) RC(4,2) RC(0,0)   // row4 col1 占位（无按键）
        >;
    };
};

&flash0 {
    partitions {
        compatible = "fixed-partitions";
        #address-cells = <1>;
        #size-cells = <1>;

        boot_partition: partition@0 {
            label = "mcuboot";
            reg = <0x00000000 0x00010000>;
        };
        slot0_partition: partition@10000 {
            label = "image-0";
            reg = <0x00010000 0x0006A000>;
        };
        slot1_partition: partition@7A000 {
            label = "image-1";
            reg = <0x0007A000 0x0006A000>;
        };
        code_partition: partition@E4000 {
            label = "image-2";
            reg = <0x000E4000 0x0001C000>;
        };
        storage_partition: partition@100000 {
            label = "storage";
            reg = <0x00100000 0x00080000>;
        };
    };
};